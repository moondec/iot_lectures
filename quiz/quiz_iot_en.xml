<question type="multichoice">
  <name><text>W3-08: IoT privacy</text></name>
  <questiontext format="html"><text><![CDATA[<p>What privacy threat can smart energy meters pose?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>Based on power consumption peak analysis, they can determine when the resident is at home, when cooking, and when sleeping</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>They can eavesdrop on phone calls through the electrical socket</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>They transmit images from a built-in camera to the energy supplier</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>They pose no privacy threat</p>]]></text></answer>
</question>

