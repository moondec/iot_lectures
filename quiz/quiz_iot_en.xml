  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>LoRaWAN allows building your own gateways in the free radio band, without subscription fees</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>LoRaWAN requires a SIM card and subscription from a telecommunications operator</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>LoRaWAN works only in buildings and is not suitable for field applications</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>LoRaWAN offers higher throughput than Wi-Fi</p>]]></text></answer>
</question>

<question type="multichoice">
