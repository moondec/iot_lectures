<question type="multichoice">
  <name><text>W3-01: Cloud Computing</text></name>
  <questiontext format="html"><text><![CDATA[<p>Why is raw data from IoT sensors usually aggregated at the network edge before being sent to the cloud?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>To reduce the volume of transmitted data and transmission costs – only averaged values are sent to the cloud</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Because the cloud cannot process numerical data</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Due to legal regulations prohibiting transmission of raw data over the Internet</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Cloud computing does not support MQTT protocol</p>]]></text></answer>
</question>

