  <answer fraction="0" format="html"><text><![CDATA[<p>64 bytes</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>1 kilobyte</p>]]></text></answer>
</question>

<question type="multichoice">
