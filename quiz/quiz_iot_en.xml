<!-- ===================== LECTURE 1 (10 questions) ===================== -->

<question type="multichoice">
  <name><text>W1-01: First IoT device</text></name>
  <questiontext format="html"><text><![CDATA[<p>Which device at Carnegie Mellon University (1982) is considered the first example of the "Internet of Things"?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>A Coca-Cola vending machine connected to ARPANET</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>A laser printer controlled remotely</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>A weather station with a telephone modem</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>A CCTV camera with digital transmission</p>]]></text></answer>
</question>

