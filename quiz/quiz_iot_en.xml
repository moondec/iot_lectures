</question>

<question type="multichoice">
  <name><text>W2-08: MQTT Pub/Sub</text></name>
  <questiontext format="html"><text><![CDATA[<p>How does the Publish/Subscribe (Pub/Sub) architecture work in MQTT protocol?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>A sensor publishes data to a central Broker under a specific topic, and the Broker sends it to all interested subscribers</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>The sensor connects directly to each data recipient through a dedicated channel</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>The server queries the sensor every second (polling) for current values</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Data is transmitted via broadcast to all devices on the local network</p>]]></text></answer>
</question>

