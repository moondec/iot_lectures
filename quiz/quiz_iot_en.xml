<question type="multichoice">
  <name><text>W1-04: IoT layers</text></name>
  <questiontext format="html"><text><![CDATA[<p>Which of the following sets correctly describes the three layers of IoT architecture?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
