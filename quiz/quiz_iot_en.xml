  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>Automatic finding of an alternative routing path in case of a node failure</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Automatic repair of damaged hardware by a service robot</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Automatic battery replacement in battery nodes</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Automatic switching from Zigbee to Wi-Fi upon signal loss</p>]]></text></answer>
</question>

<question type="multichoice">
  <name><text>W2-05: LPWAN</text></name>
  <questiontext format="html"><text><![CDATA[<p>What is the key feature of LPWAN (Low Power Wide Area Network) technology?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>Long range (kilometers) with drastically limited throughput and very low power consumption</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Very high throughput (gigabits) with range up to 10 meters</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Ability to transmit 4K video over 100 km distance</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Requirement of constant mains power and parabolic antenna</p>]]></text></answer>
</question>

<question type="multichoice">
  <name><text>W2-06: LoRaWAN vs NB-IoT</text></name>
  <questiontext format="html"><text><![CDATA[<p>Which feature <b>distinguishes</b> LoRaWAN from NB-IoT?</p>]]></text></questiontext>
