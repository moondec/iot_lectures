  <answer fraction="0" format="html"><text><![CDATA[<p>Physical – Transport – Session</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Sensors – Database – Website</p>]]></text></answer>
</question>

<question type="multichoice">
  <name><text>W1-05: Passive sensors</text></name>
  <questiontext format="html"><text><![CDATA[<p>Which of the following sensors is an example of a <b>passive</b> sensor (does not require power for detection)?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>Photoresistor</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Ultrasonic sensor</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Lidar</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Doppler radar</p>]]></text></answer>
</question>

<question type="multichoice">
  <name><text>W1-06: Edge Computing</text></name>
  <questiontext format="html"><text><![CDATA[<p>What is Edge Computing in the context of IoT?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>Processing and filtering data close to the source (device) before it reaches the cloud</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Transmitting all raw data directly to the cloud without processing</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>A server cooling technology located at the building edge</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>A special type of Wi-Fi network operating outdoors</p>]]></text></answer>
</question>

<question type="multichoice">
  <name><text>W1-07: ESP32</text></name>
  <questiontext format="html"><text><![CDATA[<p>What distinguishes the ESP32 microcontroller from Arduino Uno in IoT applications?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>It has built-in Wi-Fi and Bluetooth modules and very low power consumption in sleep mode</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>It runs full Linux with a graphical user interface</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>It is much larger physically and more expensive than Arduino</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>It has no GPIO ports</p>]]></text></answer>
</question>

<question type="multichoice">
  <name><text>W1-08: Deep Sleep</text></name>
  <questiontext format="html"><text><![CDATA[<p>What is the "Deep Sleep" paradigm in IoT microcontrollers?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>The processor cuts off its power, wakes up for a fraction of a second, performs measurement and data transmission, then goes back to sleep</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>The processor runs continuously but reduces clock frequency by 50%</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>The device turns off at night and turns on automatically in the morning</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>The battery is charged with solar energy during processor sleep</p>]]></text></answer>
</question>

<question type="multichoice">
  <name><text>W1-09: Digital Twin</text></name>
  <questiontext format="html"><text><![CDATA[<p>What is the concept of a "Digital Twin"?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>A virtual copy of a physical object powered by real-time sensor data, enabling simulations</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>A backup copy of microcontroller firmware stored in the cloud</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Two identical physical sensors placed side by side for redundancy</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>An AI algorithm analyzing historical data without connection to the real object</p>]]></text></answer>
</question>

<question type="multichoice">
  <name><text>W1-10: Raspberry Pi in IoT</text></name>
  <questiontext format="html"><text><![CDATA[<p>For which task is Raspberry Pi (SBC) best suited in IoT architecture?</p>]]></text></questiontext>
