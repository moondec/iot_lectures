<question type="multichoice">
  <name><text>W1-07: ESP32</text></name>
  <questiontext format="html"><text><![CDATA[<p>Co wyróżnia mikrokontroler ESP32 na tle Arduino Uno w zastosowaniach IoT?</p>]]></text></questiontext>
