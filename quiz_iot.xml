<question type="multichoice">
  <name><text>W3-04: Smart City Barcelona</text></name>
  <questiontext format="html"><text><![CDATA[<p>Jaką oszczędność energetyczną przyniosło inteligentne oświetlenie miejskie w Barcelonie?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>Około 30% budżetu energetycznego rocznie</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Około 90% budżetu energetycznego rocznie</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Brak oszczędności – system był nieopłacalny</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Około 5% budżetu energetycznego rocznie</p>]]></text></answer>
</question>

<question type="multichoice">
  <name><text>W3-05: Predictive Maintenance</text></name>
  <questiontext format="html"><text><![CDATA[<p>Na czym polega koncepcja Predictive Maintenance (konserwacja predykcyjna) w Przemyśle 4.0?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>Przewidywanie awarii maszyn na podstawie analizy danych z czujników (wibracji, temperatur) zanim fizycznie do nich dojdzie</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Planowe wyłączanie maszyn co tydzień w celu manualnego przeglądu</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Naprawianie maszyn dopiero po ich całkowitym uszkodzeniu</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Instalowanie zapasowych maszyn na wypadek awarii głównych</p>]]></text></answer>
</question>

<question type="multichoice">
  <name><text>W3-06: Botnet Mirai</text></name>
  <questiontext format="html"><text><![CDATA[<p>Jakie urządzenia IoT zostały przejęte przez botnet Mirai w 2016 roku do przeprowadzenia ataku DDoS?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>Niezabezpieczone kamery IP z domyślnymi hasłami</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Inteligentne lodówki Samsung</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Samochody autonomiczne Tesla</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Satelity komunikacyjne Starlink</p>]]></text></answer>
</question>

<question type="multichoice">
  <name><text>W3-07: Segmentacja sieci</text></name>
  <questiontext format="html"><text><![CDATA[<p>Dlaczego urządzenia IoT powinny być umieszczane w osobnej sieci VLAN?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>Aby włamanie do niezabezpieczonego czujnika nie dawało dostępu do głównej sieci biurowej i serwerów</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Aby zwiększyć przepustowość Wi-Fi dla laptopów pracowników</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Ze względu na limit urządzeń w protokole Zigbee</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>VLAN jest wymagany przez protokół MQTT</p>]]></text></answer>
</question>

<question type="multichoice">
  <name><text>W3-08: Prywatność IoT</text></name>
  <questiontext format="html"><text><![CDATA[<p>Jakie zagrożenie dla prywatności mogą nieść inteligentne liczniki energii?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>Na podstawie analizy pików zużycia energii mogą określić, kiedy mieszkaniec jest w domu, kiedy gotuje i kiedy śpi</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Mogą podsłuchiwać rozmowy telefoniczne przez gniazdko elektryczne</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Przesyłają obraz z wbudowanej kamery do dostawcy energii</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Nie stanowią żadnego zagrożenia dla prywatności</p>]]></text></answer>
</question>

<question type="multichoice">
  <name><text>W3-09: E-Waste</text></name>
  <questiontext format="html"><text><![CDATA[<p>Jaki problem ekologiczny generuje masowa produkcja urządzeń IoT?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>Miliardy jednorazowych urządzeń z bateriami niemożliwymi do wymiany tworzą ogromną ilość elektronicznych śmieci (e-waste)</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Zwiększone zużycie wody pitnej przez procesy chłodzenia mikrokontrolerów</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Hałas generowany przez czujniki ultradźwiękowe zagraża populacjom ptaków</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Promieniowanie elektromagnetyczne czujników IoT powoduje globalny efekt cieplarniany</p>]]></text></answer>
</question>

