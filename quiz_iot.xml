<question type="multichoice">
  <name><text>W1-08: Deep Sleep</text></name>
  <questiontext format="html"><text><![CDATA[<p>Na czym polega paradygmat „Deep Sleep" w mikrokontrolerach IoT?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>Procesor odcina sobie zasilanie, budzi się na ułamek sekundy, wykonuje pomiar i nadanie danych, po czym ponownie zasypia</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Procesor działa cały czas, ale zmniejsza taktowanie zegara o 50%</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Urządzenie wyłącza się na noc i włącza rano automatycznie</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Bateria jest ładowana energią słoneczną podczas uśpienia procesora</p>]]></text></answer>
</question>

<question type="multichoice">
