  <answer fraction="0" format="html"><text><![CDATA[<p>Zakaz sprzedaży urządzeń IoT konsumentom indywidualnym</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Obowiązek stosowania wyłącznie protokołu HTTP w komunikacji IoT</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Nakaz instalowania systemu Linux na wszystkich urządzeniach IoT</p>]]></text></answer>
