  <answer fraction="0" format="html"><text><![CDATA[<p>BLE przesyła strumieniowo dźwięk w jakości Hi-Fi</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>BLE wymaga stałego zasilania sieciowego 230 V</p>]]></text></answer>
</question>

