<question type="multichoice">
  <name><text>W2-02: Wi-Fi w IoT</text></name>
  <questiontext format="html"><text><![CDATA[<p>Dlaczego Wi-Fi jest <b>słabym</b> wyborem dla autonomicznych czujników IoT zasilanych bateryjnie?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
