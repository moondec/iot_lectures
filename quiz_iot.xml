<question type="multichoice">
  <name><text>W2-05: LPWAN</text></name>
  <questiontext format="html"><text><![CDATA[<p>Jaka jest kluczowa cecha technologii LPWAN (Low Power Wide Area Network)?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>Duży zasięg (kilometry) przy drastycznie ograniczonej przepustowości i bardzo niskim poborze energii</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Bardzo duża przepustowość (gigabity) przy zasięgu do 10 metrów</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Możliwość transmisji wideo 4K na dystansie 100 km</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>Wymaganie stałego zasilania sieciowego i anteny parabolicznej</p>]]></text></answer>
</question>

<question type="multichoice">
  <name><text>W2-06: LoRaWAN vs NB-IoT</text></name>
  <questiontext format="html"><text><![CDATA[<p>Która cecha <b>odróżnia</b> LoRaWAN od NB-IoT?</p>]]></text></questiontext>
  <defaultgrade>1</defaultgrade>
  <penalty>0.3333333</penalty>
  <single>true</single>
  <shuffleanswers>true</shuffleanswers>
  <answer fraction="100" format="html"><text><![CDATA[<p>LoRaWAN pozwala na budowę własnych bramek w darmowym paśmie radiowym, bez opłat abonamentowych</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>LoRaWAN wymaga karty SIM i abonamentu u operatora telekomunikacyjnego</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>LoRaWAN działa wyłącznie w budynkach i nie nadaje się do zastosowań terenowych</p>]]></text></answer>
  <answer fraction="0" format="html"><text><![CDATA[<p>LoRaWAN oferuje wyższą przepustowość niż Wi-Fi</p>]]></text></answer>
</question>

